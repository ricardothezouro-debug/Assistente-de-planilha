{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Finly Assistente financeiro",
  "version": "0.1.0",
  "identifier": "local.financeiro.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Finly Assistente financeiro",
        "width": 1280,
        "height": 820,
        "minWidth": 1050,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/financeiro-api"],
    "icon": ["icons/icon.ico"]
  }
}
